{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

convertToMeters 1;

vertices
(
    (-400 -100   0)   // 0
    (0.01 -100   0)   // 1
    (0.01  100   0)   // 2
    (-400  100   0)   // 3

    (-400 -100  85)   // 4
    (0.01 -100  85)   // 5
    (0.01  100  85)   // 6
    (-400  100  85)   // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7)
    (20 20 10)
    simpleGrading (1 1 1)
);

edges
(
);

boundary
(
    inlet
    {
        type patch;

        faces
        (
            (0 3 7 4)
        );
    }

    outlet
    {
        type patch;

        faces
        (
            (1 5 6 2)
        );
    }

    walls
    {
        type wall;

        faces
        (
            (0 1 2 3)   // z = 0
            (4 7 6 5)   // z = 85

            (0 4 5 1)   // y = -100
            (3 2 6 7)   // y = 100
        );
    }
);

