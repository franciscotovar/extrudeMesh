FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       surfaceScalarField;
    location    "1";
    object      faceZone;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform -1;

boundaryField
{
    sides
    {
        type            calculated;
        value           uniform -1;
    }
    originalPatch
    {
        type            calculated;
        value           uniform -1;
    }
    otherSide
    {
        type            calculated;
        value           uniform -1;
    }
}


